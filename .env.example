# ==============================================
# متغيرات البيئة لمتجر تَرِفَة
# Environment Variables for Tarifa Store
# ==============================================

# قاعدة البيانات (PostgreSQL - Neon)
# Database Connection String
DATABASE_URL="postgresql://username:password@host:5432/database?sslmode=require"

# ----------------------------------------------
# ImageKit - رفع وتخزين الصور في السحابة
# Cloud Image Storage
# ----------------------------------------------
IMAGEKIT_PRIVATE_KEY="private_axKYAD+8m9LUQdlR0G/RvTZM4mg="
NEXT_PUBLIC_IMAGEKIT_PUBLIC_KEY="public_Wksh6UwSA7ogAHZPkF8DZNaDMMA="
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT="https://ik.imagekit.io/tarifastore"

# ----------------------------------------------
# JWT - تشفير الجلسات
# Session Encryption
# ----------------------------------------------
JWT_SECRET="your-secure-random-jwt-secret-key"

# ----------------------------------------------
# Email - خدمة البريد (Brevo/Sendinblue)
# Email Service
# ----------------------------------------------
BREVO_API_KEY="xkeysib-your-api-key"
EMAIL_FROM="noreply@yourdomain.com"

