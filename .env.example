# ==========================================
# 🛡️ Tarifa Store - Environment Variables
# ⚠️ CHANGE ALL SECRETS IN PRODUCTION!
# ==========================================

# --- Database ---
DATABASE_URL="postgresql://user:password@localhost:5432/tarifa_store?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/tarifa_store?schema=public"

# --- Authentication & Security ---
# ⚠️ CRITICAL: Generate with: openssl rand -base64 64
JWT_SECRET="CHANGE_ME_TO_RANDOM_64_CHAR_STRING_NOW"
JWT_REFRESH_SECRET="CHANGE_ME_TO_ANOTHER_RANDOM_STRING"
NEXTAUTH_SECRET="CHANGE_THIS_TOO"
BCRYPT_SALT_ROUNDS="12"

# --- Admin Account ---
ADMIN_EMAIL="admin@tarifa.com"
ADMIN_PHONE="+967776080395"

# --- Email Service (Brevo) ---
BREVO_API_KEY="xkeysib-your-key-here"
BREVO_SENDER_EMAIL="noreply@yourdomain.com"
BREVO_SENDER_NAME="متجر ترفة"

# --- Image Upload (ImageKit) ---
IMAGEKIT_PUBLIC_KEY=""
IMAGEKIT_PRIVATE_KEY=""
IMAGEKIT_URL_ENDPOINT="https://ik.imagekit.io/your_id"

# --- Real-time (Pusher) ---
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER="ap2"

# --- CORS Configuration ---
ALLOWED_ORIGINS="http://localhost:3000,https://yourdomain.com"

# --- Application ---
NODE_ENV="development"
APP_URL="http://localhost:3000"
CURRENCY_CODE="YER"