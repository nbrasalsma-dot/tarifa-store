{
  "name": "tarifa-store",
  "version": "0.2.1-secured",
  "private": true,
  "description": "متجر ترفة - Tarifa Store Yemeni E-commerce Platform",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "npx prisma generate && npx prisma db push && next build && cp -r .next/static .next/standalone/.next/ && cp -r public .next/standalone/"
    "start": "NODE_ENV=production bun .next/standalone/server.js",
    "lint": "eslint .",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:setup": "prisma migrate dev --name init && tsx prisma/seed.ts"
  },
